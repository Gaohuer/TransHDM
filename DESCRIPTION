Package: TransHDM
Title: High-Dimensional Mediation Analysis via Transfer Learning
Version: 1.0.1
Authors@R: 
    c(
    person(given="Huer", family="Gao", email="gaohuer@proton.me", role=c("aut", "cre","cph")),
